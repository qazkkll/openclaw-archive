B\u306e\u6700\u65b0\u306e\u30d5\u30a9\u30fc\u30e010-K\u300110-Q\u30018-K\u3092\u542b\u3080\u5f53\u793e\u306e\u516c\u958b\u63d0\u51fa\u7269\u3067\u8a73\u8ff0\u3055\u308c\u3066\u3044\u308b\u305d\u306e\u4ed6\u306e\u30ea\u30b9\u30af\u3084\u4e0d\u78ba\u5b9f\u6027\u304c\u3042\u308a\u307e\u3059\u304c\u3001\u305d\u308c\u3089\u306b\u9650\u5b9a\u3055\u308c\u307e\u305b\u3093\u3002\u4eee\u306b\u3001\u3053\u308c\u3089\u307e\u305f\u306f\u305d\u306e\u4ed6\u306e\u30ea\u30b9\u30af\u307e\u305f\u306f\u4e0d\u78ba\u5b9f\u6027\u306e1\u3064\u306a\u3044\u3057\u8907\u6570\u304c\u5b9f\u73fe\u3057\u305f\u5834\u5408\uff08\u307e\u305f\u306f\u305d\u306e\u3088\u3046\u306a\u5c55\u958b\u306e\u5f71\u97ff\u304c\u5909\u5316\u3057\u305f\u5834\u5408\uff09\u3001\u3042\u308b\u3044\u306f\u524d\u63d0\u6761\u4ef6\u304c\u4e0d\u6b63\u78ba\u3067\u3042\u308b\u3068\u5224\u660e\u3057\u305f\u5834\u5408\u3001\u5b9f\u969b\u306e\u7d50\u679c\u304c\u5f53\u793e\u306e\u5c06\u6765\u898b\u901a\u3057\u306b\u95a2\u3059\u308b\u8a18\u8ff0\u306b\u53cd\u6620\u3055\u308c\u3066\u3044\u308b\u3082\u306e\u3068\u306f\u5927\u304d\u304f\u7570\u306a\u308b\u5834\u5408\u304c\u3042\u308a\u307e\u3059\u3002\u5c06\u6765\u898b\u901a\u3057\u306b\u95a2\u3059\u308b\u8a18\u8ff0\u306f\u3001\u672c\u30ea\u30ea\u30fc\u30b9\u767a\u8868\u6642\u70b9\u3067\u306e\u5185\u5bb9\u3067\u3042\u308a\u3001\u4e21\u5f53\u4e8b\u8005\u306f\u3001\u65b0\u305f\u306a\u60c5\u5831\u3001\u5c06\u6765\u306e\u51fa\u6765\u4e8b\u3001\u305d\u306e\u4ed6\u306e\u7406\u7531\u306b\u304b\u304b\u308f\u3089\u305a\u3001\u305d\u306e\u3088\u3046\u306a\u8a18\u8ff0\u3092\u516c\u5f0f\u306b\u66f4\u65b0\u307e\u305f\u306f\u6539\u8a02\u3059\u308b\u4e00\u5207\u306e\u610f\u56f3\u304a\u3088\u3073\u7fa9\u52d9\u3092\u5426\u8a8d\u3057\u307e\u3059\u3002 \u672c\u8a18\u8005\u767a\u8868\u6587\u306e\u516c\u5f0f\u30d0\u30fc\u30b8\u30e7\u30f3\u306f\u30aa\u30ea\u30b8\u30ca\u30eb\u8a00\u8a9e\u7248\u3067\u3059\u3002\u7ffb\u8a33\u8a00\u8a9e\u7248\u306f\u3001\u8aad\u8005\u306e\u4fbf\u5b9c\u3092\u56f3\u308b\u76ee\u7684\u3067\u63d0\u4f9b\u3055\u308c\u305f\u3082\u306e\u3067\u3042\u308a\u3001\u6cd5\u7684\u52b9\u529b\u3092\u6301\u3061\u307e\u305b\u3093\u3002\u7ffb\u8a33\u8a00\u8a9e\u7248\u3092\u8cc7\u6599\u3068\u3057\u3066\u3054\u5229\u7528\u306b\u306a\u308b\u969b\u306b\u306f\u3001\u6cd5\u7684\u52b9\u529b\u3092\u6709\u3059\u308b\u552f\u4e00\u306e\u30d0\u30fc\u30b8\u30e7\u30f3\u3067\u3042\u308b\u30aa\u30ea\u30b8\u30ca\u30eb\u8a00\u8a9e\u7248\u3068\u7167\u3089\u3057\u5408\u308f\u305b\u3066\u9802\u304f\u3088\u3046\u304a\u9858\u3044\u81f4\u3057\u307e\u3059\u3002", "published_at": "2022-11-02 08:48:00", "publisher": "Business Wire", "source": "fmp"}, {"ticker": "LIN", "title": "SLB\u4e0e\u6797\u5fb7\u5408\u4f5c\u8fdb\u884c\u78b3\u6355\u96c6\u4e0e\u5c01\u5b58", "text": "\u4f11\u65af\u6566--(BUSINESS WIRE)--(\u7f8e\u56fd\u5546\u4e1a\u8d44\u8baf)--SLB (NYSE: SLB) \u548c\u6797\u5fb7\u516c\u53f8(Linde, NYSE: LIN; FWB: LIN)\u4eca\u5929\u5ba3\u5e03\uff0c\u53cc\u65b9\u5df2\u7ecf\u5c31\u78b3\u6355\u96c6\u3001\u5229\u7528\u548c\u5c01\u5b58(CCUS)\u9879\u76ee\u8fbe\u6210\u6218\u7565\u5408\u4f5c\uff0c\u4ece\u800c\u52a0\u901f\u5de5\u4e1a\u548c\u80fd\u6e90\u9886\u57df\u7684\u8131\u78b3\u89e3\u51b3\u65b9\u6848\u3002\u8fd9\u9879\u5408\u4f5c\u5c06\u6574\u5408\u53cc\u65b9\u51e0\u5341\u5e74\u6765\u5728\u4e8c\u6c27\u5316\u78b3\u6355\u83b7\u548c\u5c01\u5b58\u65b9\u9762\u7684\u7ecf\u9a8c\u3001\u521b\u65b0\u7684\u6280\u672f\u7ec4\u5408\u3001\u9879\u76ee\u5f00\u53d1\u548c\u6267\u884c\u4e13\u957f\uff0c\u4ee5\u53ca\u5de5\u7a0b\u3001\u91c7\u8d2d\u548c\u65bd\u5de5(EPC)\u80fd\u529b\u3002 \u8bb8\u591a\u5de5\u4e1a\u548c\u80fd\u6e90\u5e94\u7528\u90fd\u5b58\u5728\u6216\u4ea7\u751f\u4e8c\u6c27\u5316\u78b3\u3002\u8fd9\u9879\u5408\u4f5c\u5c06\u805a\u7126\u4ee5\u4e8c\u6c27\u5316\u78b3\u4e3a\u526f\u4ea7\u54c1\u7684\u6c22\u6c14\u548c\u6c28\u6c14\u751f\u4ea7\uff0c\u4ee5\u53ca\u5929\u7136\u6c14\u52a0\u5de5\u3002CCUS\u51cf\u5c11\u4e86\u8fd9\u4e9b\u80fd\u6e90\u5bc6\u96c6\u578b\u884c\u4e1a\u7684\u6392\u653e\uff0c\u521b\u9020\u4e86\u65b0\u7684\u4f4e\u78b3\u80fd\u6e90\u548c\u4ea7\u54c1\u3002\u56fd\u9645\u80fd\u6e90\u7f72(IEA)\u9884\u8ba11\uff0c\u82e5\u5b9e\u73b02050\u5e74\u51c0\u96f6\u6392\u653e\u7684\u76ee\u6807\uff0c\u6bcf\u5e74\u9700\u8981\u901a\u8fc7CCUS\u51cf\u5c11\u8d85\u8fc760\u4ebf\u5428\u7684\u4e8c\u6c27\u5316\u78b3\u3002 SLB\u9996\u5e2d\u6267\u884c\u5b98Olivier Le Peuch\u8868\u793a\uff1a\u201c\u5728\u521b\u5efa\u5730\u7403\u6240\u9700\u7684\u8131\u78b3\u80fd\u6e90\u7cfb\u7edf\uff0c\u4ee5\u5e73\u8861\u80fd\u6e90\u9700\u6c42\u548c\u6c14\u5019\u76ee\u6807\u65b9\u9762\uff0cCCUS\u81f3\u4e3a\u91cd\u8981\u3002\u6211\u4eec\u5f88\u9ad8\u5174\u4e0e\u6797\u5fb7\u5408\u4f5c\u5f00\u53d1CCUS\u9879\u76ee\uff0c\u4e3a\u4f20\u7edf\u80fd\u6e90\u9886\u57df\u7684\u4f4e\u78b3\u80fd\u6e90\u4ea7\u54c1\u589e\u957f\u63d0\u4f9b\u652f\u6301\u3002\u201d \u6797\u5fb7\u9996\u5e2d\u6267\u884c\u5b98Sanjiv Lamba\u8868\u793a\uff1a\u201c\u78b3\u6355\u96c6\u4e0e\u5c01\u5b58\u5c06\u662f\u89e3\u51b3\u5168\u7403\u53d8\u6696\u95ee\u9898\u7684\u4e00\u4e2a\u5173\u952e\u6760\u6746\u3002\u6211\u4eec\u81f4\u529b\u4e8e\u5e2e\u52a9\u5ba2\u6237\u4ee5\u5177\u6709\u6210\u672c\u6548\u76ca\u7684\u65b9\u5f0f\u5b9e\u73b0\u8fd0\u8425\u8131\u78b3\u3002\u5728SLB\u7684\u5e2e\u52a9\u4e0b\uff0c\u6211\u4eec\u80fd\u591f\u63d0\u4f9b\u6280\u672f\u9a71\u52a8\u7684\u89e3\u51b3\u65b9\u6848\u2014\u2014\u6db5\u76d6\u4ece\u6267\u884c\u590d\u6742EPC\u9879\u76ee\u5230\u4fdd\u969c\u53ef\u9760\u548c\u5b89\u5168\u957f\u671f\u50a8\u5b58\u7684\u65b9\u65b9\u9762\u9762\u3002\u201d SLB\u548c\u6797\u5fb7\u5df2\u7ecf\u6295\u5165\u4e00\u5e74\u591a\u7684\u65f6\u95f4\u53d1\u6398\u8131\u78b3\u673a\u4f1a\u3002\u53cc\u65b9\u5c06\u51ed\u501f\u5728\u591a\u4e2a\u9886\u57df\u548c\u884c\u4e1a\u7684\u5168\u7403\u4e1a\u52a1\u7248\u56fe\u6765\u6269\u5927\u5ba2\u6237\u8303\u56f4\uff0c\u5e76\u7740\u91cd\u8bbe\u8ba1\u4e3a\u6240\u6709\u5229\u76ca\u76f8\u5173\u8005\u5b9e\u73b0\u4ef7\u503c\u6700\u5927\u5316\u7684\u4e1a\u52a1\u548c\u8fd0\u8425\u6a21\u5f0f\u3002 \u5173\u4e8eSLB SLB (NYSE: SLB)\u662f\u4e00\u5bb6\u8de8\u56fd\u79d1\u6280\u516c\u53f8\uff0c\u81f4\u529b\u4e8e\u63a8\u52a8\u80fd\u6e90\u521b\u65b0\uff0c\u5b9e\u73b0\u5730\u7403\u73af\u5883\u751f\u6001\u5e73\u8861\u3002\u6211\u4eec\u7684\u4e1a\u52a1\u904d\u5e03\u5168\u7403100\u591a\u4e2a\u56fd\u5bb6\u548c\u5730\u533a\uff0c\u800c\u5458\u5de5\u7684\u6765\u6e90\u5730\u51e0\u4e4e\u662f\u8fd0\u8425\u56fd\u5bb6\u548c\u5730\u533a\u7684\u4e24\u500d\u3002\u6211\u4eec\u6bcf\u5929\u90fd\u81f4\u529b\u4e8e\u5b9e\u73b0\u77f3\u6cb9\u5929\u7136\u6c14\u7684\u8131\u78b3\uff0c\u5f00\u53d1\u53ef\u6269\u5c55\u7684\u65b0\u80fd\u6e90\u6280\u672f\uff0c\u4ee5\u52a0\u901f\u80fd\u6e90\u8f6c\u578b\u3002\u5982\u9700\u4e86\u89e3\u66f4\u591a\u4fe1\u606f\uff0c\u8bf7\u8bbf\u95eeslb.com\u3002 \u5173\u4e8e\u6797\u5fb7 \u6797\u5fb7\u662f\u4e00\u5bb6\u5168\u7403\u9886\u5148\u7684\u5de5\u4e1a\u6c14\u4f53\u548c\u5de5\u7a0b\u516c\u53f8\uff0c2021\u5e74\u9500\u552e\u989d\u8fbe310\u4ebf\u7f8e\u5143\uff08260\u4ebf\u6b27\u5143\uff09\u3002\u6bcf\u4e00\u5929\uff0c\u6211\u4eec\u90fd\u77e2\u5fd7\u4e0d\u6e1d\uff0c\u8df5\u884c\u4f01\u4e1a\u4f7f\u547d\u2014\u2014\u7cbe\u76ca\u4e30\u4ea7\uff0c\u60e0\u6cfd\u5168\u7403\uff0c\u4ee5\u9ad8\u8d28\u91cf\u7684\u6280\u672f\u3001\u670d\u52a1\u548c\u89e3\u51b3\u65b9\u6848\uff0c\u5e2e\u52a9\u5ba2\u6237\u53d6\u5f97\u66f4\u5927\u7684\u6210\u529f\uff0c\u540c\u65f6\u4fdd\u62a4\u6211\u4eec\u7684\u5730\u7403\uff0c\u4f7f\u4e4b\u53ef\u6301\u7eed\u53d1\u5c55\u3002 \u6797\u5fb7\u6240\u89e6\u53ca\u7684\u7ec8\u7aef\u5e02\u573a\u6db5\u76d6\u4f17\u591a\u884c\u4e1a\uff0c\u5305\u62ec\u5316\u5de5\u4e0e\u7cbe\u70bc\u3001\u98df\u54c1\u4e0e\u996e\u6599\u3001\u7535\u5b50\u3001\u533b\u7597\u5065\u5eb7\u3001\u5236\u9020\u4e1a\u3001\u91d1\u5c5e\u548c\u91c7\u77ff\u4e1a\u7b49\u3002\u6797\u5fb7\u6240\u751f\u4ea7\u7684\u5de5\u4e1a\u6c14\u4f53\u5e94\u7528\u4e8e\u5404\u79cd\u9886\u57df\u2014\u2014\u4ece\u533b\u9662\u7528\u6c27\u5230\u7528\u4e8e\u7535\u5b50\u884c\u4e1a\u7684\u9ad8\u7eaf\u53ca\u7279\u79cd\u6c14\u4f53\uff0c\u518d\u5230\u7528\u4e8e\u6e05\u6d01\u80fd\u6e90\u7684\u6c22\u6c14\u7b49\u3002\u540c\u65f6\uff0c\u6797\u5fb7\u8fd8\u63d0\u4f9b\u4e00\u7cfb\u5217\u5148\u8fdb\u7684\u6c14\u4f53\u5904\u7406\u89e3\u51b3\u65b9\u6848\u4ee5\u652f\u6301\u5ba2\u6237\u4e1a\u52a1\u53d1\u5c55\u3001\u63d0\u5347\u6548\u7387\u5e76\u51cf\u5c11\u78b3\u6392\u653e\u91cf\u3002 \u5982\u9700\u4e86\u89e3\u66f4\u591a\u6709\u5173\u6797\u5fb7\u53ca\u5176\u4ea7\u54c1\u548c\u670d\u52a1\u7684\u4fe1\u606f\uff0c\u8bf7\u8bbf\u95ee\uff1awww.linde.com\u3002 1 IEA (2022)\uff0c\u56fd\u9645\u80fd\u6e90\u7f72\u300a2022\u5e74\u4e16\u754c\u80fd\u6e90\u5c55\u671b\u300b\uff0c\u5df4\u9ece\u3002https://www.iea.org/reports/world-energy-outlook-2022 \u6709\u5173\u524d\u77bb\u6027\u9648\u8ff0\u7684\u8b66\u793a\u6027\u58f0\u660e \u672c\u65b0\u95fb\u7a3f\u5305\u542b\u7f8e\u56fd\u8054\u90a6\u8bc1\u5238\u6cd5\u6240\u754c\u5b9a\u7684\u201c\u524d\u77bb\u6027\u9648\u8ff0\u201d\uff0c\u5373\u5173\u4e8e\u672a\u6765\u800c\u4e0d\u662f\u5386\u53f2\u4e8b\u4ef6\u7684\u9648\u8ff0\u3002\u6b64\u7c7b\u9648\u8ff0\u901a\u5e38\u542b\u6709\u201c\u9884\u8ba1\u201d\u3001\u201c\u6216\u8bb8\u201d\u3001\u201c\u53ef\u4ee5\u201d\u3001\u201c\u4f30\u8ba1\u201d\u3001\u201c\u6253\u7b97\u201d\u3001\u201c\u9884\u671f\u201d\u3001\u201c\u5c06\u201d\u3001\u201c\u6f5c\u5728\u201d\u3001\u201c\u9884\u6d4b\u201d\u548c\u5176\u4ed6\u7c7b\u4f3c\u8bcd\u8bed\u3002\u524d\u77bb\u6027\u9648\u8ff0\u5728\u4e0d\u540c\u7a0b\u5ea6\u4e0a\u6d89\u53ca\u4e0d\u786e\u5b9a\u7684\u4e8b\u9879\uff0c\u5982\u5173\u4e8e\u78b3\u6355\u96c6\u6280\u672f\u7684\u90e8\u7f72\u548c\u9884\u671f\u6548\u76ca\u53ca\u4f19\u4f34\u5173\u7cfb\u7684\u9884\u671f\u6548\u76ca\uff1b\u5173\u4e8e\u53ef\u6301\u7eed\u6027\u548c\u73af\u5883\u4e8b\u9879\u7684\u76ee\u6807\u3001\u8ba1\u5212\u548c\u9884\u6d4b\u7684\u9648\u8ff0\uff1b\u5173\u4e8e\u80fd\u6e90\u8fc7\u6e21\u548c\u5168\u7403\u6c14\u5019\u53d8\u5316\u7684\u9884\u6d4b\u6216\u9884\u671f\uff1b\u4ee5\u53ca\u8fd0\u8425\u7a0b\u5e8f\u548c\u6280\u672f\u7684\u6539\u8fdb\u3002\u6b64\u7c7b\u9648\u8ff0\u53d7\u98ce\u9669\u548c\u4e0d\u786e\u5b9a\u6027\u7684\u5f71\u54cd\uff0c\u5305\u62ec\u4f46\u4e0d\u9650\u4e8e\uff1a\u65e0\u6cd5\u5b9e\u73b0\u51c0-\u8d1f\u78b3\u6392\u653e\u76ee\u6807\uff1b\u65e0\u6cd5\u5b9e\u73b0\u78b3\u6355\u83b7\u6218\u7565\u3001\u5021\u8bae\u6216\u4f19\u4f34\u5173\u7cfb\u7684\u9884\u671f\u6548\u76ca\uff1b\u5e94\u5bf9\u73af\u5883\u95ee\u9898\u7684\u7acb\u6cd5\u548c\u76d1\u7ba1\u5021\u8bae\uff0c\u5305\u62ec\u5e94\u5bf9\u5168\u7403\u6c14\u5019\u53d8\u5316\u5f71\u54cd\u7684\u5021\u8bae\uff1b\u76d1\u7ba1\u6279\u51c6\u548c\u8bb8\u53ef\u7684\u65f6\u95f4\u5b89\u6392\u6216\u63a5\u6536\uff1b\u4ee5\u53ca\u516c\u53f8\u516c\u5f00\u6587\u4ef6\u4e2d\u8be6\u8ff0\u7684\u5176\u4ed6\u98ce\u9669\u548c\u4e0d\u786e\u5b9a\u6027\u3002\u6b64\u7c7b\u6587\u4ef6\u5305\u62ecSLB\u6700\u8fd1\u5411\u7f8e\u56fd\u8bc1\u5238\u4ea4\u6613\u59d4\u5458\u4f1a\u62a5\u5907\u6216\u63d0\u4ea4\u7684Form 10-K\u300110-Q\u548c8-K\u6587\u4ef6\u4e2d\u8be6\u8ff0\u7684\u5176\u4ed6\u98ce\u9669\u6216\u4e0d\u786e\u5b9a\u6027\u3002\u5982\u679c\u4e00\u9879\u6216\u591a\u9879\u4e0a\u8ff0\u6216\u5176\u4ed6\u98ce\u9669\u6216\u4e0d\u786e\u5b9a\u6027\u53d8\u4e3a\u73b0\u5b9e\uff08\u6216\u6b64\u7c7b\u4e8b\u6001\u53d8\u5316\u5bfc\u81f4\u5f71\u54cd\uff09\uff0c\u6216\u8005\u4e8b\u5b9e\u8bc1\u660e\u57fa\u672c\u63a8\u65ad\u5b58\u5728\u95ee\u9898\uff0c\u90a3\u4e48\u5b9e\u9645\u7ed3\u679c\u53ef\u80fd\u4f1a\u4e0e\u5728\u6211\u4eec\u524d\u77bb\u6027\u9648\u8ff0\u4e2d\u6240\u63cf\u8ff0\u7684\u5185\u5bb9\u5b58\u5728\u91cd\u5927\u504f\u5dee\u3002\u524d\u77bb\u6027\u9648\u8ff0\u4ec5\u9488\u5bf9\u622a\u81f3\u672c\u65b0\u95fb\u7a3f\u53d1\u5e03\u4e4b\u65e5\u7684\u60c5\u51b5\uff0c\u65e0\u8bba\u662f\u5426\u51fa\u73b0\u65b0\u4fe1\u606f\u3001\u672a\u6765\u4e8b\u4ef6\u6216\u5176\u4ed6\u539f\u56e0\uff0c\u53cc\u65b9\u4e0d\u6253\u7b97\u4e5f\u6ca1\u6709\u4e49\u52a1\u516c\u5f00\u66f4\u65b0\u6216\u4fee\u6539\u8fd9\u4e9b\u9648\u8ff0\u3002 \u514d\u8d23\u58f0\u660e\uff1a\u672c\u516c\u544a\u4e4b\u539f\u6587\u7248\u672c\u4e43\u5b98\u65b9\u6388\u6743\u7248\u672c\u3002\u8bd1\u6587\u4ec5\u4f9b\u65b9\u4fbf\u4e86\u89e3\u4e4b\u7528\uff0c\u70e6\u8bf7\u53c2\u7167\u539f\u6587\uff0c\u539f\u6587\u7248\u672c\u4e43\u552f\u4e00\u5177\u6cd5\u5f8b\u6548\u529b\u4e4b\u7248\u672c\u3002", "published_at": "2022-11-02 03:53:00", "publisher": "Business Wire", "source": "fmp"}, {"ticker": "LIN", "title": "SLB\u8207\u6797\u5fb7\u5408\u4f5c\u9032\u884c\u78b3\u6355\u96c6\u8207\u5c01\u5b58", "text": "\u4f11\u58eb\u9813--(BUSINESS WIRE)--(\u7f8e\u570b\u5546\u696d\u8cc7\u8a0a)--SLB (NYSE: SLB) \u548c\u6797\u5fb7\u516c\u53f8(Linde, NYSE: LIN; FWB: LIN)\u4eca\u5929\u5ba3\u4f48\uff0c\u96d9\u65b9\u5df2\u7d93\u5c31\u78b3\u6355\u96c6\u3001\u5229\u7528\u548c\u5c01\u5b58(CCUS)\u5c08\u6848\u5efa\u7acb\u7b56\u7565\u6027\u5408\u4f5c\uff0c\u5f9e\u800c\u52a0\u901f\u5de5\u696d\u548c\u80fd\u6e90\u9818\u57df\u7684\u812b\u78b3\u89e3\u6c7a\u65b9\u6848\u3002\u9019\u9805\u5408\u4f5c\u5c07\u6574\u5408\u96d9\u65b9\u5e7e\u5341\u5e74\u4f86\u5728\u4e8c\u6c27\u5316\u78b3\u6355\u96c6\u548c\u5c01\u5b58\u65b9\u9762\u7684\u7d93\u9a57\u3001\u5275\u65b0\u7684\u79d1\u6280\u7d44\u5408\u3001\u5c08\u6848\u958b\u767c\u548c\u57f7\u884c\u5c08\u9577\uff0c\u4ee5\u53ca\u5de5\u7a0b\u3001\u63a1\u8cfc\u548c\u65bd\u5de5(EPC)\u80fd\u529b\u3002 \u8a31\u591a\u5de5\u696d\u548c\u80fd\u6e90\u61c9\u7528\u90fd\u5b58\u5728\u6216\u7522\u751f\u4e8c\u6c27\u5316\u78b3\u3002\u9019\u9805\u5408\u4f5c\u5c07\u805a\u7126\u4ee5\u4e8c\u6c27\u5316\u78b3\u70ba\u526f\u7522\u54c1\u7684\u6c2b\u6c23\u548c\u6c28\u6c23\u751f\u7522\uff0c\u4ee5\u53ca\u5929\u7136\u6c23\u52a0\u5de5\u3002CCUS\u6e1b\u5c11\u4e86\u9019\u4e9b\u80fd\u6e90\u5bc6\u96c6\u578b\u5de5\u696d\u7684\u6392\u653e\uff0c\u5275\u9020\u65b0\u7684\u4f4e\u78b3\u80fd\u6e90\u548c\u7522\u54c1\u3002\u570b\u969b\u80fd\u6e90\u7e3d\u7f72(IEA)\u9810\u4f301\uff0c\u82e5\u8981\u57282050\u5e74\u4e4b\u524d\u9054\u6210\u6de8\u96f6\u6392\u653e\u7684\u76ee\u6a19\uff0c\u6bcf\u5e74\u9700\u8981\u5229\u7528CCUS\u6e1b\u5c11\u8d85\u904e60\u5104\u5678\u7684\u4e8c\u6c27\u5316\u78b3\u3002 SLB\u57f7\u884c\u9577Olivier Le Peuch\u8868\u793a\uff1a\u300c\u5728\u5275\u5efa\u5730\u7403\u6240\u9700\u7684\u812b\u78b3\u80fd\u6e90\u7cfb\u7d71\uff0c\u4ee5\u5e73\u8861\u80fd\u6e90\u9700\u6c42\u548c\u6c23\u5019\u76ee\u6a19\u65b9\u9762\uff0cCCUS\u81f3\u70ba\u91cd\u8981\u3002\u6211\u5011\u5f88\u9ad8\u8208\u8207\u6797\u5fb7\u5408\u4f5c\u958b\u767cCCUS\u5c08\u6848\uff0c\u70ba\u50b3\u7d71\u80fd\u6e90\u9818\u57df\u4f4e\u78b3\u80fd\u6e90\u7522\u54c1\u7684\u6210\u9577\u63d0\u4f9b\u652f\u63f4\u3002\u300d \u6797\u5fb7\u57f7\u884c\u9577Sanjiv Lamba\u8868\u793a\uff1a\u300c\u78b3\u6355\u96c6\u8207\u5c01\u5b58\u5c07\u662f\u89e3\u6c7a\u5168\u7403\u6696\u5316\u554f\u984c\u7684\u95dc\u9375\u69d3\u687f\u3002\u6211\u5011\u81f4\u529b\u65bc\u5354\u52a9\u5ba2\u6236\u4ee5\u5177\u6709\u6210\u672c\u6548\u76ca\u7684\u65b9\u5f0f\uff0c\u4f7f\u5b83\u5011\u7684\u696d\u52d9\u904b\u4f5c\u812b\u78b3\u3002\u5728SLB\u7684\u5e6b\u52a9\u4e0b\uff0c\u6211\u5011\u80fd\u5920\u63d0\u4f9b\u79d1\u6280\u9a45\u52d5\u7684\u89e3\u6c7a\u65b9\u6848\u2014\u2014\u5f9e\u8907\u96dcEPC\u5c08\u6848\u7684\u57f7\u884c\uff0c\u5230\u78ba\u4fdd\u53ef\u9760\u548c\u5b89\u5168\u7684\u9577\u671f\u5132\u5b58\u3002\u300d SLB\u548c\u6797\u5fb7\u5df2\u7d93\u6295\u5165\u4e00\u5e74\u591a\u7684\u6642\u9593\u767c\u6398\u812b\u78b3\u6a5f\u6703\u3002\u96d9\u65b9\u5c07\u6191\u85c9\u5728\u591a\u500b\u9818\u57df\u548c\u7522\u696d\u7684\u5168\u7403\u696d\u52d9\u7248\u5716\u4f86\u64f4\u5927\u5ba2\u6236\u7bc4\u570d\uff0c\u4e26\u5c08\u6ce8\u65bc\u8a2d\u8a08\u70ba\u6240\u6709\u5229\u5bb3\u95dc\u4fc2\u8005\u64f4\u5927\u50f9\u503c\u7684\u696d\u52d9\u548c\u71df\u904b\u6a21\u5f0f\u3002 \u95dc\u65bcSLB SLB (NYSE: SLB)\u662f\u5168\u7403\u6027\u79d1\u6280\u516c\u53f8\uff0c\u81f4\u529b\u65bc\u63a8\u52d5\u80fd\u6e90\u5275\u65b0\uff0c\u4f7f\u5730\u7403\u74b0\u5883\u751f\u614b\u4fdd\u6301\u5e73\u8861\u3002\u6211\u5011\u7684\u696d\u52d9\u904d\u4f48\u5168\u7403100\u591a\u500b\u570b\u5bb6\u548c\u5730\u5340\uff0c\u800c\u54e1\u5de5\u7684\u4f86\u6e90\u5730\u5e7e\u4e4e\u662f\u71df\u904b\u6240\u5728\u570b\u5bb6\u548c\u5730\u5340\u7684\u5169\u500d\u3002\u6211\u5011\u6bcf\u5929\u90fd\u81f4\u529b\u65bc\u63a8\u52d5\u77f3\u6cb9\u5929\u7136\u6c23\u7684\u812b\u78b3\uff0c\u958b\u767c\u53ef\u64f4\u5145\u7684\u65b0\u80fd\u6e90\u79d1\u6280\uff0c\u4ee5\u52a0\u901f\u80fd\u6e90\u8f49\u578b\u3002\u5982\u6b32\u77ad\u89e3\u66f4\u591a\u8cc7\u8a0a\uff0c\u8acb\u9020\u8a2aslb.com\u3002 \u95dc\u65bc\u6797\u5fb7 \u6797\u5fb7\u662f\u5168\u7403\u9996\u5c48\u4e00\u6307\u7684\u5de5\u696d\u6c23\u9ad4\u548c\u5de5\u7a0b\u516c\u53f8\uff0c2021\u5e74\u92b7\u552e\u984d\u9054310\u5104\u7f8e\u5143\uff08260\u5104\u6b50\u5143\uff09\u3002\u6bcf\u4e00\u5929\uff0c\u6211\u5011\u90fd\u77e2\u5fd7\u4e0d\u6e1d\uff0c\u5c65\u884c\u4f01\u696d\u4f7f\u547d\u2014\u2014\u7cbe\u76ca\u8c50\u7522\uff0c\u60e0\u6fa4\u5168\u7403\uff0c\u4ee5\u9ad8\u54c1\u8cea\u7684\u79d1\u6280\u3001\u670d\u52d9\u548c\u89e3\u6c7a\u65b9\u6848\uff0c\u5354\u52a9\u5ba2\u6236\u53d6\u5f97\u66f4\u5927\u7684\u6210\u529f\uff0c\u540c\u6642\u4fdd\u8b77\u6211\u5011\u7684\u5730\u7403\uff0c\u4f7f\u4e4b\u6c38\u7e8c\u767c\u5c55\u3002 \u6797\u5fb7\u6240\u89f8\u53ca\u7684\u7d42\u7aef\u5e02\u5834\u6db5\u84cb\u773e\u591a\u7522\u696d\uff0c\u5305\u62ec\u5316\u5de5\u8207\u7cbe\u7149\u3001\u98df\u54c1\u8207\u98f2\u6599\u3001\u96fb\u5b50\u3001\u91ab\u7642\u5065\u5eb7\u3001\u88fd\u9020\u696d\u3001\u91d1\u5c6c\u548c\u63a1\u7926\u696d\u7b49\u3002\u6797\u5fb7\u6240\u751f\u7522\u7684\u5de5\u696d\u6c23\u9ad4\u61c9\u7528\u65bc\u5404\u7a2e\u9818\u57df\u2014\u2014\u5f9e\u91ab\u9662\u7528\u6c27\u5230\u7528\u65bc\u96fb\u5b50\u696d\u7684\u9ad8\u7d14\u53ca\u7279\u6b8a\u6c23\u9ad4\uff0c\u518d\u5230\u7528\u65bc\u6f54\u6de8\u80fd\u6e90\u7684\u6c2b\u6c23\u7b49\u3002\u540c\u6642\uff0c\u6797\u5fb7\u9084\u63d0\u4f9b\u4e00\u7cfb\u5217\u5148\u9032\u7684\u6c23\u9ad4\u8655\u7406\u89e3\u6c7a\u65b9\u6848\uff0c\u4ee5\u652f\u63f4\u5ba2\u6236\u696d\u52d9\u767c\u5c55\u3001\u63d0\u5347\u6548\u7387\u4e26\u6e1b\u5c11\u78b3\u6392\u653e\u91cf\u3002 \u5982\u6b32\u77ad\u89e3\u66f4\u591a\u6709\u95dc\u6797\u5fb7\u53ca\u5176\u7522\u54c1\u548c\u670d\u52d9\u7684\u8cc7\u8a0a\uff0c\u8acb\u9020\u8a2a\uff1awww.linde.com\u3002 1 IEA (2022)\uff0c\u570b\u969b\u80fd\u6e90\u7e3d\u7f72\u300a2022\u5e74\u4e16\u754c\u80fd\u6e90\u5c55\u671b\u300b\uff0c\u5df4\u9ece\u3002https://www.iea.org/reports/world-energy-outlook-2022 \u6709\u95dc\u524d\u77bb\u6027\u9673\u8ff0\u7684\u8b66\u793a\u6027\u8072\u660e \u672c\u65b0\u805e\u7a3f\u5305\u542b\u7f8e\u570b\u806f\u90a6\u8b49\u5238\u6cd5\u6240\u754c\u5b9a\u7684\u300c\u524d\u77bb\u6027\u9673\u8ff0\u300d\uff0c\u5373\u95dc\u65bc\u672a\u4f86\u800c\u4e0d\u662f\u6b77\u53f2\u4e8b\u4ef6\u7684\u9673\u8ff0\u3002\u6b64\u985e\u9673\u8ff0\u901a\u5e38\u542b\u6709\u300c\u9810\u8a08 \u300d\u3001\u300c\u6216\u8a31 \u300d\u3001\u300c\u53ef\u4ee5 \u300d\u3001\u300c\u4f30\u8a08 \u300d\u3001\u300c\u6253\u7b97 \u300d\u3001\u300c\u9810\u671f \u300d\u3001\u300c\u5c07 \u300d\u3001\u300c\u6f5b\u5728 \u300d\u3001\u300c\u9810\u6e2c \u300d\u548c\u5176\u4ed6\u985e\u4f3c\u8a5e\u8a9e\u3002\u524d\u77bb\u6027\u9673\u8ff0\u5728\u4e0d\u540c\u7a0b\u5ea6\u4e0a\u6d89\u53ca\u4e0d\u78ba\u5b9a\u7684\u4e8b\u9805\uff0c\u5982\u95dc\u65bc\u78b3\u6355\u96c6\u6280\u8853\u7684\u90e8\u7f72\u548c\u9810\u671f\u6548\u76ca\u53ca\u5925\u4f34\u95dc\u4fc2\u7684\u9810\u671f\u6548\u76ca\uff1b\u95dc\u65bc\u6c38\u7e8c\u6027\u548c\u74b0\u5883\u4e8b\u9805\u7684\u76ee\u6a19\u3001\u8a08\u756b\u548c\u9810\u6e2c\u7684\u9673\u8ff0\uff1b\u95dc\u65bc\u80fd\u6e90\u8f49\u578b\u548c\u5168\u7403\u6c23\u5019\u8b8a\u9077\u7684\u9810\u6e2c\u6216\u9810\u671f\uff1b\u4ee5\u53ca\u4f5c\u696d\u7a0b\u5e8f\u548c\u79d1\u6280\u7684\u6539\u9032\u3002\u6b64\u985e\u9673\u8ff0\u53d7\u98a8\u96aa\u548c\u4e0d\u78ba\u5b9a\u6027\u7684\u5f71\u97ff\uff0c\u5305\u62ec\u4f46\u4e0d\u9650\u65bc\uff1a\u7121\u6cd5\u9054\u6210\u6de8-\u8ca0\u78b3\u6392\u653e\u76ee\u6a19\uff1b\u7121\u6cd5\u8a8d\u5217\u78b3\u6355\u96c6\u7b56\u7565\u3001\u5021\u8b70\u6216\u5925\u4f34\u95dc\u4fc2\u7684\u9810\u671f\u6548\u76ca\uff1b\u61c9\u5c0d\u74b0\u5883\u554f\u984c\u7684\u7acb\u6cd5\u548c\u76e3\u7ba1\u5021\u8b70\uff0c\u5305\u62ec\u61c9\u5c0d\u5168\u7403\u6c23\u5019\u8b8a\u9077\u5f71\u97ff\u7684\u5021\u8b70\uff1b\u76e3\u7ba1\u6279\u51c6\u548c\u8a31\u53ef\u7684\u6642\u6a5f\u6216\u63a5\u6536\uff1b\u4ee5\u53ca\u516c\u53f8\u516c\u958b\u6587\u4ef6\u4e2d\u8a73\u8ff0\u7684\u5176\u4ed6\u98a8\u96aa\u548c\u4e0d\u78ba\u5b9a\u6027\u3002\u6b64\u985e\u6587\u4ef6\u5305\u62ecSLB\u6700\u8fd1\u5411\u7f8e\u570b\u8b49\u5238\u4ea4\u6613\u59d4\u54e1\u6703\u5831\u5099\u6216\u905e\u4ea4\u7684Form 10-K\u300110-Q\u548c8-K\u4e2d\u8a73\u8ff0\u7684\u5176\u4ed6\u98a8\u96aa\u6216\u4e0d\u78ba\u5b9a\u6027\u3002\u5982\u679c\u4e00\u9805\u6216\u591a\u9805\u4e0a\u8ff0\u6216\u5176\u4ed6\u98a8\u96aa\u6216\u4e0d\u78ba\u5b9a\u6027\u6210\u70ba\u4e8b\u5be6\uff08\u6216\u6b64\u985e\u4e8b\u614b\u8b8a\u5316\u5c0e\u81f4\u7684\u5f8c\u679c\uff09\uff0c\u6216\u8005\u4e8b\u5be6\u8b49\u660e\u57fa\u672c\u63a8\u65b7\u5b58\u5728\u554f\u984c\uff0c\u90a3\u9ebc\u5be6\u969b\u7d50\u679c\u53ef\u80fd\u6703\u8207\u5728\u6211\u5011\u524d\u77bb\u6027\u9673\u8ff0\u4e2d\u6240\u63cf\u8ff0\u7684\u5167\u5bb9\u5b58\u5728\u91cd\u5927\u504f\u5dee\u3002\u524d\u77bb\u6027\u9673\u8ff0\u50c5\u91dd\u5c0d\u622a\u81f3\u672c\u65b0\u805e\u7a3f\u767c\u4f48\u4e4b\u65e5\u7684\u60c5\u6cc1\uff0c\u7121\u8ad6\u662f\u5426\u51fa\u73fe\u65b0\u8cc7\u8a0a\u3001\u672a\u4f86\u4e8b\u4ef6\u6216\u5176\u4ed6\u539f\u56e0\uff0c\u96d9\u65b9\u4e0d\u6253\u7b97\u4e5f\u6c92\u6709\u7fa9\u52d9\u516c\u958b\u66f4\u65b0\u6216\u4fee\u6539\u9019\u4e9b\u9673\u8ff0\u3002 \u514d\u8cac\u8072\u660e\uff1a\u672c\u516c\u544a\u4e4b\u539f\u6587\u7248\u672c\u4e43\u5b98\u65b9\u6388\u6b0a\u7248\u672c\u3002\u8b6f\u6587\u50c5\u4f9b\u65b9\u4fbf\u77ad\u89e3\u4e4b\u7528\uff0c\u7169\u8acb\u53c3\u7167\u539f\u6587\uff0c\u539f\u6587\u7248\u672c\u4e43\u552f\u4e00\u5177\u6cd5\u5f8b\u6548\u529b\u4e4b\u7248\u672c\u3002 \u806f\u7d61\u65b9\u5f0f:", "published_at": "2022-11-02 03:53:00", "publisher": "Business Wire", "source": "fmp"}, {"ticker": "LIN", "title": "2 Hydrogen Stocks For Your November 2022 Watchlist", "text": "Are these the top hydrogen stocks to invest in right now?", "published_at": "2022-11-01 21:07:30", "publisher": "Stockmarket.com", "source": "fmp"}]